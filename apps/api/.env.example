ANTHROPIC_API_KEY=sk-ant-api03-your-key
TAVILY_API_KEY=tvly-your-key

# Anthropic docs currently list Claude Sonnet 4.6 as `claude-sonnet-4-6`.
ANTHROPIC_MODEL=claude-sonnet-4-6
PORT=8787

# Set to true only for local development without API credentials.
RESEARCH_ALLOW_MOCK=false
RESEARCH_MAX_SEARCH_RESULTS=6
RESEARCH_MAX_EXTRACT_URLS=5
